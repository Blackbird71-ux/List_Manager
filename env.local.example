# Copy to .env.local and fill in.

# SQLite database file. Dev: local file. Prod (Docker): file:/data/listsmanager.db
DATABASE_URL="file:./prisma/dev.db"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public URL of the app (prod: https://lists.liddleapps.com)
AUTH_URL="http://localhost:3400"
