# Copy to .env.local and fill in.
# IMPORTANT: no quotes around values. This file is also fed to Docker via
# --env-file on the NAS, and Docker keeps quotes as part of the value.

# SQLite database file. Dev: local file. Prod (Docker): file:/data/listsmanager.db
DATABASE_URL=file:./prisma/dev.db

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (prod: https://lists.liddleapps.com).
# Also used as the origin for password-reset links.
AUTH_URL=http://localhost:3400

# SMTP for password-reset emails (same credentials as HomeBase's email setup).
# Leave unset to disable self-service reset — admins can still reset passwords
# from Admin -> Users.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Optional, defaults to SMTP_USER
SMTP_FROM=

# Optional: pin the secret the overdue-digest cron uses to call the API.
# If unset, the container generates a fresh one on every start.
# DIGEST_SECRET=
