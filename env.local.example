# Copy to .env.local and fill in.
# IMPORTANT: no quotes around values. This file is also fed to Docker via
# --env-file on the NAS, and Docker keeps quotes as part of the value.

# SQLite database file. Dev: local file. Prod (Docker): file:/data/listsmanager.db
DATABASE_URL=file:./prisma/dev.db

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Do NOT set AUTH_URL. Auth works on any host (trustHost), and an https
# AUTH_URL makes browsers reject the login cookies over plain-http LAN access.
# The public URL for password-reset email links is APP_URL, set by
# deploy-nas.sh / docker-compose.yml in production. Leave unset in dev
# (links then use the request origin, i.e. http://localhost:3400).
# APP_URL=

# Note: SMTP for password-reset emails is NOT set here — admins configure it
# in the app under Settings -> Email; it is stored in the database.

# Optional: pin the secret the overdue-digest cron uses to call the API.
# If unset, the container generates a fresh one on every start.
# DIGEST_SECRET=
