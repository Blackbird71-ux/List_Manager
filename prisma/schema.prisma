// ListsManager — reusable checklist templates with recurring instances.
// SQLite via better-sqlite3 driver adapter (see src/lib/prisma.ts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// A tenant: a company or family. All users and their data belong to exactly
// one organisation and nothing is ever visible across the boundary.
model Organization {
  id         String   @id @default(cuid())
  name       String
  // Shared with colleagues so they can join this org at registration.
  inviteCode String   @unique
  // The org created when the instance was first set up. Its admins manage
  // instance-level settings (email server, remote-access tunnel).
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  users       User[]
  departments Department[]
  templates   Template[]
  checklists  Checklist[]
}

// A group of users within an organisation (e.g. "Finance", "Operations").
// Checklists with visibility "department" are visible to members of any of
// the checklist's departments.
model Department {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  createdAt      DateTime     @default(now())

  members    DepartmentMember[]
  checklists ChecklistDepartment[]

  @@unique([organizationId, name])
}

// Users can belong to any number of departments.
model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([userId])
}

// Which departments a "department"-visibility checklist is shown to.
model ChecklistDepartment {
  id           String     @id @default(cuid())
  checklistId  String
  checklist    Checklist  @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([checklistId, departmentId])
  @@index([departmentId])
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  password       String // bcrypt hash
  role           String       @default("member") // "admin" | "manager" | "member"
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  // Self-service password reset: sha256 of the emailed one-time token.
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?

  createdTemplates  Template[]      @relation("TemplateCreator")
  createdChecklists Checklist[]     @relation("ChecklistCreator")
  assignedChecklists Checklist[]    @relation("ChecklistAssignee")
  assignedItems     ChecklistItem[] @relation("ItemAssignee")
  notifications     Notification[]
  attachments       Attachment[]
  checklistShares   ChecklistShare[]
  comments          Comment[]
  pushSubscriptions PushSubscription[]
  departments       DepartmentMember[]

  @@index([organizationId])
}

// A browser's Web Push subscription (one row per device/browser). Endpoint is
// unique so re-subscribing the same browser updates rather than duplicates.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// App-wide key/value settings (e.g. "smtp" -> JSON config), edited by admins
// in Settings. Kept in the DB so secrets never live in .env files.
model AppSetting {
  key   String @id
  value String
}

// A reusable master template. Copying it into a Checklist never mutates it.
model Template {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  category    String   @default("general") // free-form grouping label
  // "none" | "daily" | "weekly" | "fortnightly" | "monthly" | "quarterly" | "yearly"
  recurrence  String   @default("none")
  archived    Boolean  @default(false)
  // Bumped whenever the template's items or fields are edited, so completed
  // checklists can show which version of the template they ran from.
  version     Int      @default(1)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdById String
  createdBy   User     @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items        TemplateItem[]
  customFields CustomFieldDef[]
  checklists   Checklist[]

  @@index([organizationId])
}

model TemplateItem {
  id         String  @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  text       String
  priority   String? // "low" | "medium" | "high"
  sortOrder  Int     @default(0)

  @@index([templateId])
}

model CustomFieldDef {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  type       String // "text" | "dropdown" | "user"
  options    String  @default("[]") // JSON array of strings (dropdown only)
  required   Boolean @default(true)
  sortOrder  Int     @default(0)

  @@index([templateId])
}

// A working instance, optionally copied from a Template.
model Checklist {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  category    String    @default("general")
  status      String    @default("active") // "active" | "completed"
  // "team": everyone in the organisation can see and work on it.
  // "department": members of the checklist's departments (see departments below).
  // "private": creator, assignees, shared users, managers and admins only.
  visibility  String    @default("team")
  priority    String    @default("medium") // "low" | "medium" | "high"
  // Copied from the template at creation so ad-hoc lists can also recur.
  recurrence  String    @default("none")
  dueDate     DateTime?
  completedAt DateTime?

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  // Snapshot of template.version at creation time (null for ad-hoc lists).
  templateVersion Int?

  // Recurrence chain: set once when the next instance is spawned; also the
  // double-spawn guard (spawn only if null).
  nextInstanceId String? @unique

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById  String
  createdBy    User    @relation("ChecklistCreator", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?   @relation("ChecklistAssignee", fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       ChecklistItem[]
  fieldValues CustomFieldValue[]
  shares      ChecklistShare[]
  comments    Comment[]
  activity    ActivityLog[]
  departments ChecklistDepartment[]

  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([createdById])
  @@index([templateId])
}

// A comment on a checklist — the conversation half of the activity feed.
model Comment {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  body        String
  createdAt   DateTime  @default(now())

  @@index([checklistId, createdAt])
}

// Audit trail of who changed what on a checklist. Actor name is denormalized
// so the history survives user deletion.
model ActivityLog {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  actorName   String
  // "created" | "item_checked" | "item_unchecked" | "item_added" | "item_removed"
  // | "completed" | "reopened" | "reordered" | "assigned" | "visibility_changed"
  // | "shared" | "unshared" | "commented" | "edited"
  action      String
  detail      String    @default("")
  createdAt   DateTime  @default(now())

  @@index([checklistId, createdAt])
}

// Grants a specific user access to a private checklist.
model ChecklistShare {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([checklistId, userId])
  @@index([userId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  text        String
  checked     Boolean   @default(false)
  notes       String    @default("")
  priority    String?
  dueDate     DateTime?
  sortOrder   Int       @default(0)

  assignedToId String?
  assignedTo   User?   @relation("ItemAssignee", fields: [assignedToId], references: [id])
  checkedByName String?
  checkedAt    DateTime?

  attachments Attachment[]

  @@index([checklistId])
  @@index([assignedToId])
}

model CustomFieldValue {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  name        String
  type        String
  value       String    @default("")

  @@index([checklistId])
}

// File metadata; bytes live on disk under DATA_DIR/attachments/.
model Attachment {
  id           String        @id @default(cuid())
  itemId       String
  item         ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  size         Int
  storagePath  String // relative path under the attachments dir
  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([itemId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String
  read        Boolean  @default(false)
  checklistId String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}
